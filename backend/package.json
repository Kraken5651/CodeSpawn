{
  "name": "codekraken-backend",
  "version": "1.0.0",
  "description": "CodeKraken - Multi-Language Gamified Coding Learning Platform Backend",
  "main": "src/app.js",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "build": "echo 'Node.js backend has no build step'",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:integration": "jest --testPathPattern=integration",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write 'src/**/*.js'",
    "migrate": "sequelize db:migrate",
    "migrate:undo": "sequelize db:migrate:undo",
    "migrate:undo:all": "sequelize db:migrate:undo:all",
    "migrate:create": "sequelize migration:create",
    "migrate:status": "sequelize db:migrate:status",
    "seed": "sequelize db:seed:all",
    "seed:undo": "sequelize db:seed:undo:all"
  },
  "keywords": [
    "codekraken",
    "coding",
    "game-development",
    "learning",
    "gamification"
  ],
  "author": "CodeKraken Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "sequelize": "^6.35.2",
    "pg": "^8.11.3",
    "redis": "^4.6.13",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.1.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.0",
    "morgan": "^1.10.0",
    "joi": "^17.11.0",
    "axios": "^1.6.5",
    "socket.io": "^4.7.2",
    "bull": "^4.11.5",
    "child-process-promise": "^2.3.1",
    "winston": "^3.11.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-github2": "^0.1.12",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.0",
    "nodemailer": "^6.9.7"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.55.0",
    "prettier": "^3.1.1",
    "sequelize-cli": "^6.6.1",
    "@types/jest": "^29.5.10"
  }
}
