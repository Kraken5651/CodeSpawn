# ============================================================================
# ENVIRONMENT VARIABLES - CodeKraken Backend
# ============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ============================================================================
# NODE ENVIRONMENT
# ============================================================================
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000

# ============================================================================
# DATABASE - PostgreSQL
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=codekraken_dev
DB_USER=codekraken
DB_PASSWORD=your_secure_password_here
DB_URL=postgresql://codekraken:your_secure_password_here@localhost:5432/codekraken_dev
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_LOGGING=false

# ============================================================================
# REDIS - Session & Cache Store
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# JWT & SECURITY
# ============================================================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
ACCESS_TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# ============================================================================
# SESSION CONFIGURATION
# ============================================================================
SESSION_SECRET=your_session_secret_key_change_this
SESSION_EXPIRES_IN=24h

# ============================================================================
# OAUTH - Google
# ============================================================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ============================================================================
# OAUTH - GitHub
# ============================================================================
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# ============================================================================
# CODE EXECUTION
# ============================================================================
CODE_EXECUTION_TIMEOUT_MS=5000
CODE_EXECUTION_MEMORY_LIMIT_MB=256
CODE_EXECUTION_MAX_OUTPUT_SIZE=10000
CODE_EXECUTION_ISOLATED=true

# ============================================================================
# EMAIL & NOTIFICATIONS
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_password_or_app_password
SMTP_FROM_EMAIL=noreply@codekraken.dev
SMTP_FROM_NAME=CodeKraken

# ============================================================================
# FRONTEND URL
# ============================================================================
FRONTEND_URL=http://localhost:3000
FRONTEND_API_URL=http://localhost:5000/api
FRONTEND_WS_URL=ws://localhost:5000

# ============================================================================
# CORS SETTINGS
# ============================================================================
CORS_ORIGIN=http://localhost:3000,http://localhost:5000
CORS_CREDENTIALS=true

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# ============================================================================
# STORAGE - File uploads
# ============================================================================
STORAGE_TYPE=local
STORAGE_PATH=./uploads
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=10

# ============================================================================
# MONITORING & ANALYTICS
# ============================================================================
SENTRY_DSN=
APM_SERVICE_NAME=codekraken-backend
APM_SERVER_URL=

# ============================================================================
# ADMIN PANEL
# ============================================================================
ADMIN_EMAIL=admin@codekraken.dev
ADMIN_PASSWORD=change_me_in_production

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_OAUTH_ENABLED=true
FEATURE_EMAIL_NOTIFICATIONS=true
FEATURE_REAL_TIME_ENABLED=true
FEATURE_CODE_EXECUTION_ENABLED=true
FEATURE_ACHIEVEMENTS_ENABLED=true

# ============================================================================
# SECURITY
# ============================================================================
HELMET_ENABLED=true
RATE_LIMITING_ENABLED=true
CSRF_PROTECTION_ENABLED=true
CORS_ENABLED=true

# ============================================================================
# TESTING
# ============================================================================
TEST_DATABASE_URL=postgresql://codekraken:test_password@localhost:5432/codekraken_test
TEST_REDIS_URL=redis://localhost:6379/1
